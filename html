<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meus Flashcards</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="container">
        <h1>Flashcards Acadêmicos</h1>
        
        <div class="flashcard" id="card" onclick="virarCard()">
            <div class="card-inner">
                <div class="card-front">
                    <p id="pergunta">Qual é a capital da França?</p>
                    <small>Clique para virar</small>
                </div>
                <div class="card-back">
                    <p id="resposta">Paris</p>
                    <small>Clique para voltar</small>
                </div>
            </div>
        </div>

        <div class="botoes">
            <button onclick="proximoCard()">Próximo Cartão ➡️</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
